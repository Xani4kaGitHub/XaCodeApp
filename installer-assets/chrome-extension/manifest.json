{
  "manifest_version": 3,
  "name": "XaCode Chrome Bridge",
  "version": "1.0.1",
  "description": "Расширение для интеграции Google Chrome с ИИ-агентом XaCodeApp. Поддерживает постоянное WebSocket-подключение, визуальное управление и остановку по клавише Esc.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "XaCode Chrome Bridge"
  }
}
